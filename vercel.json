{
  "version": 2,
  "builds": [
    {
      "src": "web/public/**",
      "use": "@vercel/static"
    },
    {
      "src": "web/api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/web/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/web/public/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "/var/task"
  }
}
